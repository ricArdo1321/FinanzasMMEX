{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinanzasMMEX CLI Response",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ok": {
      "type": "boolean",
      "description": "True if the command was successful"
    },
    "data": {
      "description": "Result data of the command (varies by command)"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": {}
        },
        "required": ["code", "message", "details"],
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for the execution"
    }
  },
  "required": ["ok", "data", "errors", "warnings", "run_id"],
  "if": {
    "properties": { "ok": { "const": false } },
    "required": ["ok"]
  },
  "then": {
    "properties": {
      "errors": { "minItems": 1 }
    }
  }
}
