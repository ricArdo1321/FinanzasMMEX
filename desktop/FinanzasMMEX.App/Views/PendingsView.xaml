<UserControl x:Class="FinanzasMMEX.App.Views.PendingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <Label Content="Owner" />
            <TextBox Width="100" Margin="4,0"
                     Text="{Binding OwnerFilter, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="Cuenta" />
            <TextBox Width="160" Margin="4,0"
                     Text="{Binding AccountFilter, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="Estado" />
            <ComboBox Width="120" Margin="4,0" SelectedValue="{Binding StatusFilter}"
                      SelectedValuePath="Content">
                <ComboBoxItem Content="pending" />
                <ComboBoxItem Content="exported" />
                <ComboBoxItem Content="inserted" />
                <ComboBoxItem Content="rejected" />
            </ComboBox>
            <CheckBox Margin="8,4" VerticalAlignment="Center"
                      Content="Solo needs_review"
                      IsChecked="{Binding NeedsReviewOnly}" />
            <Button Content="Refrescar" Margin="8,0" Padding="12,4"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="1" Margin="8,0"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Items}"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding PostedDate}" />
                <DataGridTextColumn Header="Owner" Binding="{Binding Owner}" />
                <DataGridTextColumn Header="Cuenta" Binding="{Binding AccountAlias}" />
                <DataGridTextColumn Header="Comercio" Binding="{Binding MerchantNorm}" />
                <DataGridTextColumn Header="Monto" Binding="{Binding Amount}" />
                <DataGridTextColumn Header="Dir." Binding="{Binding Direction}" />
                <DataGridTextColumn Header="Categoría" Binding="{Binding CategoryGuess}" />
                <DataGridCheckBoxColumn Header="Review" Binding="{Binding NeedsReview}" />
                <DataGridTextColumn Header="Status" Binding="{Binding MmexStatus}" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Margin="8,4" Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
