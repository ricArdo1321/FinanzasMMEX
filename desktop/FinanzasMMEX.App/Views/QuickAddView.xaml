<UserControl x:Class="FinanzasMMEX.App.Views.QuickAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Owner" />
        <ComboBox Grid.Row="0" Grid.Column="1" SelectedValue="{Binding Owner}"
                  SelectedValuePath="Content">
            <ComboBoxItem Content="ricardo" />
            <ComboBoxItem Content="laura" />
            <ComboBoxItem Content="joint" />
        </ComboBox>

        <Label Grid.Row="1" Grid.Column="0" Content="Cuenta" />
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding AccountAlias, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="2" Grid.Column="0" Content="Monto" />
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="3" Grid.Column="0" Content="Moneda" />
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding Currency, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="4" Grid.Column="0" Content="Dirección" />
        <ComboBox Grid.Row="4" Grid.Column="1" SelectedValue="{Binding Direction}"
                  SelectedValuePath="Content">
            <ComboBoxItem Content="debit" />
            <ComboBoxItem Content="credit" />
        </ComboBox>

        <Label Grid.Row="5" Grid.Column="0" Content="Fecha" />
        <TextBox Grid.Row="5" Grid.Column="1"
                 Text="{Binding Date, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="6" Grid.Column="0" Content="Comercio" />
        <TextBox Grid.Row="6" Grid.Column="1"
                 Text="{Binding MerchantRaw, UpdateSourceTrigger=PropertyChanged}" />

        <Label Grid.Row="7" Grid.Column="0" Content="Categoría" />
        <TextBox Grid.Row="7" Grid.Column="1"
                 Text="{Binding CategoryGuess, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Crear" Padding="16,4"
                    Command="{Binding SubmitCommand}" />
            <TextBlock Margin="12,4" VerticalAlignment="Center"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>
