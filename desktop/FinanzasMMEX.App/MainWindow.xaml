<Window x:Class="FinanzasMMEX.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FinanzasMMEX.App.Views"
        mc:Ignorable="d"
        Title="FinanzasMMEX" Height="600" Width="900">
    <TabControl>
        <TabItem Header="Pendientes">
            <views:PendingsView DataContext="{Binding Pendings}" />
        </TabItem>
        <TabItem Header="Quick Add">
            <views:QuickAddView DataContext="{Binding QuickAdd}" />
        </TabItem>
    </TabControl>
</Window>
